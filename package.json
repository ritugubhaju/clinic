{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint resources/js",
    "lint:fix": "eslint resources/js --fix",
    "format": "prettier --write \"resources/js/**/*.{js,vue}\"",
    "format:check": "prettier --check \"resources/js/**/*.{js,vue}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "resources/js/**/*.{js,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "app/**/*.php": [
      "vendor/bin/pint"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@inertiajs/vue3": "^1.0.0",
    "@tailwindcss/forms": "^0.5.3",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "autoprefixer": "^10.4.21",
    "axios": "^1.6.4",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "husky": "^9.1.7",
    "laravel-vite-plugin": "^2.1.0",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.6",
    "prettier": "^3.9.4",
    "tailwindcss": "^3.2.1",
    "vite": "^7.1.0",
    "vue": "^3.4.0"
  },
  "dependencies": {
    "pinia": "^2.2.0",
    "zod": "^4.4.3"
  }
}
